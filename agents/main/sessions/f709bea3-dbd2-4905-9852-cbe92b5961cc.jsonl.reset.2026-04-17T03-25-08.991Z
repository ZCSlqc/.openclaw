{"type":"message","id":"2b28f784","parentId":"7ff3912b","timestamp":"2026-04-16T08:58:27.880Z","message":{"role":"assistant","content":[{"type":"text","text":"好的，大哥。端口 8000 未监听（服务未运行）。我将**重启服务**，并确保监听 `0.0.0.0`（允许外部访问）。\n\n"},{"type":"toolCall","id":"call_d97dbf1b7f324e09824eebe4","name":"write","arguments":{"path":"/home/zigaa/.openclaw/workspace/workspace-develop/rag_service_local.py","content":"\"\"\"\nRAG 系统服务 - 本地模型版（FAISS + all-MiniLM-L6-v2）\n\n环境：Python 3.12 + uv venv\n技术栈：LlamaIndex + FAISS + 本地嵌入模型 + vLLM\n\"\"\"\n\nimport os\nfrom pathlib import Path\nfrom llama_index.llms.vllm import Vllm\nfrom fastapi import FastAPI\nimport uvicorn\nimport faiss\nimport numpy as np\nfrom sentence_transformers import SentenceTransformer\nimport hashlib\n\n# 配置参数\nVLLM_API_KEY = \"sk-123456789abcdef\"\nVLLM_API_URL = \"http://localhost:11434/v1\"  # 修正端口为 11434\nVLLM_MODEL_NAME = \"qwen3.5-9b\"\nMODEL_PATH = \"/home/zigaa/.openclaw/workspace/workspace-develop/models/sentence-transformers/all-MiniLM-L6-v2\"\nFAISS_DIR = \"/home/zigaa/.openclaw/workspace/workspace-develop/data/index/faiss_index\"\n\n# 简化嵌入（备用）\ndef get_embedding_simple(text):\n    hash_val = hashlib.md5(text.encode()).hexdigest()\n    hash_val = (hash_val * (768 // len(hash_val) + 1))[:768]\n    vector = [int(c, 16) / 15.0 for c in hash_val]\n    return vector\n\n# 配置 LLM 模型\nprint(\"=\" * 50)\nprint(\"RAG 系统服务启动（本地模型 + FAISS）\")\nprint(\"=\" * 50)\n\nprint(\"\\n配置 LLM 模型...\")\nasync def vllm_call(prompt, **kwargs):\n    import httpx\n    async with httpx.AsyncClient(timeout=30.0) as client:\n        response = await client.post(\n            f\"{VLLM_API_URL}/chat/completions\",\n            headers={\n                \"Authorization\": f\"Bearer {VLLM_API_KEY}\",\n                \"Content-Type\": \"application/json\"\n            },\n            json={\n                \"model\": VLLM_MODEL_NAME,\n                \"messages\": [{\"role\": \"user\", \"content\": prompt}],\n                \"temperature\": kwargs.get(\"temperature\", 0.7),\n                \"max_tokens\": kwargs.get(\"max_tokens\", 512)\n            }\n        )\n        return response.json()[\"choices\"][0][\"message\"][\"content\"]\n\nprint(f\"  vLLM API 配置：{VLLM_API_URL}\")\n\n# 配置嵌入模型\nprint(\"\\n配置嵌入模型...\")\nembed_model = None\nUSE_LOCAL_MODEL = False\ntry:\n    embed_model = SentenceTransformer(MODEL_PATH)\n    print(f\"  模型路径：{MODEL_PATH}\")\n    print(\"  模型加载成功！\")\n    USE_LOCAL_MODEL = True\nexcept Exception as e:\n    print(f\"  模型加载失败：{e}\")\n    print(\"  使用简化嵌入（备用方案）\")\n\n# 创建 FAISS 索引\nprint(\"\\n配置向量数据库（FAISS）...\")\nos.makedirs(FAISS_DIR, exist_ok=True)\nfaiss_index = faiss.IndexFlatL2(384)\nprint(f\"  FAISS 目录：{FAISS_DIR}\")\n\n# 加载文档\nprint(\"\\n加载文档...\")\ndocuments = [\n    {\"text\": \"RAG 是一种检索增强生成技术，它结合了检索和生成两种能力。\"},\n    {\"text\": \"这是一个简单的 RAG 系统示例，使用 LlamaIndex 框架。\"},\n    {\"text\": \"LlamaIndex 是一个用于构建 RAG 应用的框架。\"}\n]\n\n# 创建索引\nprint(\"\\n创建索引...\")\nif USE_LOCAL_MODEL:\n    print(\"  使用本地嵌入模型...\")\n    texts = [doc[\"text\"] for doc in documents]\n    embeddings = embed_model.encode(texts, show_progress_bar=True)\n    embeddings_np = np.array(embeddings, dtype=np.float32)\n    faiss_index.add(embeddings_np)\n    print(f\"  已添加 {len(texts)} 个文档\")\n    print(\"  索引构建成功（使用本地模型）！\")\nelse:\n    print(\"  使用简化嵌入...\")\n    texts = [doc[\"text\"] for doc in documents]\n    embeddings = np.array([get_embedding_simple(text) for text in texts], dtype=np.float32)\n    faiss_index.add(embeddings)\n    print(f\"  已添加 {len(texts)} 个文档\")\n    print(\"  索引构建成功（使用简化嵌入）！\")\n\nprint(\"\\n\" + \"=\" * 50)\nprint(\"RAG 系统服务启动成功！\")\nprint(\"=\" * 50)\n\n# 启动 FastAPI 服务（监听 0.0.0.0，允许外部访问）\napp = FastAPI(title=\"RAG API\")\n\n@app.get(\"/query\")\nasync def query(query_text: str):\n    try:\n        response = await vllm_call(query_text)\n        return {\"answer\": response, \"status\": \"success\"}\n    except Exception as e:\n        return {\"answer\": f\"Error: {str(e)}\", \"status\": \"error\"}\n\n@app.get(\"/health\")\nasync def health():\n    return {\"status\": \"ok\", \"service\": \"RAG API\"}\n\nprint(\"\\n启动 FastAPI 服务...\")\nprint(\"  本地访问：http://localhost:8000\")\nprint(\"  远程访问：http://192.168.10.239:8000\")\nprint(\"  健康检查：http://192.168.10.239:8000/health\")\nprint(\"  查询接口：http://192.168.10.239:8000/query?query_text=你的问题\")\n\n# 监听 0.0.0.0（所有网络接口）\nuvicorn.run(app, host=\"0.0.0.0\", port=8000, log_level=\"warning\")"}}],"api":"openai-completions","provider":"vllm","model":"qwen3.5-9b","usage":{"input":93498,"output":1467,"cacheRead":0,"cacheWrite":0,"totalTokens":94965,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776329888990,"responseId":"chatcmpl-9db2063e6f898efd"}}
