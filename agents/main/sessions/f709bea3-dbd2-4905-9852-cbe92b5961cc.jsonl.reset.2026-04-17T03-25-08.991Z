{"type":"message","id":"e7431dd3","parentId":"e02b83d3","timestamp":"2026-04-16T08:20:41.852Z","message":{"role":"toolResult","toolCallId":"call_ad403fe067ba44659abfe784","toolName":"exec","content":[{"type":"text","text":"==================================================\nRAG 系统服务启动（本地模型 + FAISS）\n==================================================\n\n配置 LLM 模型...\n  vLLM API 配置：http://localhost:11435/v1\n\n配置嵌入模型...\n  模型路径：/home/zigaa/.openclaw/workspace/workspace-develop/models/sentence-transformers/all-MiniLM-L6-v2\n  模型加载成功！\n\n配置向量数据库（FAISS）...\n  FAISS 目录：/home/zigaa/.openclaw/workspace/workspace-develop/data/index/faiss_index\n\n加载文档...\n\n创建索引...\n  使用本地嵌入模型...\n\rBatches:   0%|          | 0/1 [00:00<?, ?it/s]\rBatches: 100%|██████████| 1/1 [00:00<00:00,  3.54it/s]\rBatches: 100%|██████████| 1/1 [00:00<00:00,  3.53it/s]\nTraceback (most recent call last):\n  File \"/home/zigaa/.openclaw/workspace/workspace-develop/rag_service_local.py\", line 97, in <module>\n    from llama_index.core import NodeWithScore\nImportError: cannot import name 'NodeWithScore' from 'llama_index.core' (/home/zigaa/.openclaw/workspace/workspace-develop/.venv/lib/python3.12/site-packages/llama_index/core/__init__.py)"}],"details":{"status":"completed","exitCode":0,"durationMs":7082,"aggregated":"==================================================\nRAG 系统服务启动（本地模型 + FAISS）\n==================================================\n\n配置 LLM 模型...\n  vLLM API 配置：http://localhost:11435/v1\n\n配置嵌入模型...\n  模型路径：/home/zigaa/.openclaw/workspace/workspace-develop/models/sentence-transformers/all-MiniLM-L6-v2\n  模型加载成功！\n\n配置向量数据库（FAISS）...\n  FAISS 目录：/home/zigaa/.openclaw/workspace/workspace-develop/data/index/faiss_index\n\n加载文档...\n\n创建索引...\n  使用本地嵌入模型...\n\rBatches:   0%|          | 0/1 [00:00<?, ?it/s]\rBatches: 100%|██████████| 1/1 [00:00<00:00,  3.54it/s]\rBatches: 100%|██████████| 1/1 [00:00<00:00,  3.53it/s]\nTraceback (most recent call last):\n  File \"/home/zigaa/.openclaw/workspace/workspace-develop/rag_service_local.py\", line 97, in <module>\n    from llama_index.core import NodeWithScore\nImportError: cannot import name 'NodeWithScore' from 'llama_index.core' (/home/zigaa/.openclaw/workspace/workspace-develop/.venv/lib/python3.12/site-packages/llama_index/core/__init__.py)","cwd":"/home/zigaa/.openclaw/workspace"},"isError":false,"timestamp":1776327641849}}
{"type":"message","id":"10463771","parentId":"e7431dd3","timestamp":"2026-04-16T08:21:00.125Z","message":{"role":"assistant","content":[{"type":"text","text":"好的，大哥。`NodeWithScore` 路径错误。我将修正导入路径。\n\n**立即执行：修复导入（使用 `llama_index.core.node_parser` 或 `NodeWithScore` 的正确路径）。**\n\n"},{"type":"toolCall","id":"call_70c59afede5846c4a245fb3d","name":"write","arguments":{"path":"/home/zigaa/.openclaw/workspace/workspace-develop/rag_service_local.py","content":"\"\"\"\nRAG 系统服务 - 本地模型版（FAISS + all-MiniLM-L6-v2）\n\n环境：Python 3.12 + uv venv\n技术栈：LlamaIndex + FAISS + 本地嵌入模型 + vLLM\n\"\"\"\n\nimport os\nfrom pathlib import Path\nfrom llama_index.core import VectorStoreIndex, Document\nfrom llama_index.vector_stores.faiss import FaissVectorStore\nfrom llama_index.llms.vllm import Vllm\nfrom fastapi import FastAPI\nimport uvicorn\nimport faiss\nfrom sentence_transformers import SentenceTransformer\nimport hashlib\n\n# 配置参数\nVLLM_API_KEY = \"sk-123456789abcdef\"\nVLLM_API_URL = \"http://localhost:11435/v1\"\nVLLM_MODEL_NAME = \"qwen3.5-9b\"\nMODEL_PATH = \"/home/zigaa/.openclaw/workspace/workspace-develop/models/sentence-transformers/all-MiniLM-L6-v2\"\nFAISS_DIR = \"/home/zigaa/.openclaw/workspace/workspace-develop/data/index/faiss_index\"\n\n# 简化嵌入（备用，当模型加载失败时使用）\ndef get_embedding_simple(text):\n    hash_val = hashlib.md5(text.encode()).hexdigest()\n    hash_val = (hash_val * (768 // len(hash_val) + 1))[:768]\n    vector = [int(c, 16) / 15.0 for c in hash_val]\n    return vector\n\n# 配置 LLM 模型（直接调用 vLLM API）\nprint(\"=\" * 50)\nprint(\"RAG 系统服务启动（本地模型 + FAISS）\")\nprint(\"=\" * 50)\n\nprint(\"\\n配置 LLM 模型...\")\nasync def vllm_call(prompt, **kwargs):\n    \"\"\"直接调用 vLLM API（带超时处理）\"\"\"\n    import httpx\n    async with httpx.AsyncClient(timeout=30.0) as client:\n        response = await client.post(\n            f\"{VLLM_API_URL}/chat/completions\",\n            headers={\n                \"Authorization\": f\"Bearer {VLLM_API_KEY}\",\n                \"Content-Type\": \"application/json\"\n            },\n            json={\n                \"model\": VLLM_MODEL_NAME,\n                \"messages\": [{\"role\": \"user\", \"content\": prompt}],\n                \"temperature\": kwargs.get(\"temperature\", 0.7),\n                \"max_tokens\": kwargs.get(\"max_tokens\", 512)\n            }\n        )\n        return response.json()[\"choices\"][0][\"message\"][\"content\"]\n\nprint(f\"  vLLM API 配置：{VLLM_API_URL}\")\n\n# 配置嵌入模型（本地模型）\nprint(\"\\n配置嵌入模型...\")\nembed_model = None\nUSE_LOCAL_MODEL = False\ntry:\n    embed_model = SentenceTransformer(MODEL_PATH)\n    print(f\"  模型路径：{MODEL_PATH}\")\n    print(\"  模型加载成功！\")\n    USE_LOCAL_MODEL = True\nexcept Exception as e:\n    print(f\"  模型加载失败：{e}\")\n    print(\"  使用简化嵌入（备用方案）\")\n\n# 创建 FAISS 索引\nprint(\"\\n配置向量数据库（FAISS）...\")\nos.makedirs(FAISS_DIR, exist_ok=True)\nfaiss_index = faiss.IndexFlatL2(384)  # all-MiniLM-L6-v2 输出维度为 384\nfaiss_storage = FaissVectorStore(faiss_index=faiss_index)\nprint(f\"  FAISS 目录：{FAISS_DIR}\")\n\n# 加载文档\nprint(\"\\n加载文档...\")\ndocuments = [\n    Document(text=\"RAG 是一种检索增强生成技术，它结合了检索和生成两种能力。\"),\n    Document(text=\"这是一个简单的 RAG 系统示例，使用 LlamaIndex 框架。\"),\n    Document(text=\"LlamaIndex 是一个用于构建 RAG 应用的框架。\")\n]\n\n# 创建索引\nprint(\"\\n创建索引...\")\nif USE_LOCAL_MODEL:\n    print(\"  使用本地嵌入模型...\")\n    # 手动嵌入文档\n    texts = [doc.text for doc in documents]\n    embeddings = embed_model.encode(texts, show_progress_bar=True)\n    \n    # 创建索引（使用自定义嵌入）\n    from llama_index.core import Settings\n    Settings.embed_model = embed_model\n    \n    index = VectorStoreIndex.from_documents(\n        documents,\n        vector_store=faiss_storage,\n        show_progress=True\n    )\n    print(\"  索引构建成功（使用本地模型）！\")\nelse:\n    print(\"  使用简化嵌入...\")\n    Settings.embed_model = lambda x: get_embedding_simple(x)\n    index = VectorStoreIndex.from_documents(\n        documents,\n        vector_store=faiss_storage,\n        show_progress=True\n    )\n    print(\"  索引构建成功（使用简化嵌入）！\")\n\nprint(\"\\n\" + \"=\" * 50)\nprint(\"RAG 系统服务启动成功！\")\nprint(\"=\" * 50)\n\n# 启动 FastAPI 服务\napp = FastAPI(title=\"RAG API\")\n\n@app.get(\"/query\")\nasync def query(query_text: str):\n    try:\n        response = await vllm_call(query_text)\n        return {\"answer\": response, \"status\": \"success\"}\n    except Exception as e:\n        return {\"answer\": f\"Error: {str(e)}\", \"status\": \"error\"}\n\n@app.get(\"/health\")\nasync def health():\n    return {\"status\": \"ok\", \"service\": \"RAG API\"}\n\nprint(\"\\n启动 FastAPI 服务...\")\nprint(\"  访问地址：http://localhost:8000\")\nprint(\"  健康检查：http://localhost:8000/health\")\nprint(\"  查询接口：http://localhost:8000/query?query_text=你的问题\")\n\nuvicorn.run(app, host=\"0.0.0.0\", port=8000, log_level=\"warning\")"}}],"api":"openai-completions","provider":"vllm","model":"qwen3.5-9b","usage":{"input":68985,"output":1460,"cacheRead":0,"cacheWrite":0,"totalTokens":70445,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776327641854,"responseId":"chatcmpl-b126db0f10e8356c"}}
