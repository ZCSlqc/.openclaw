{"type":"message","id":"5170ee2f","parentId":"7f42d2f9","timestamp":"2026-04-16T07:45:06.674Z","message":{"role":"assistant","content":[{"type":"text","text":"好的，大哥。FAISS 已安装。我将改用 FAISS 作为向量库。\n\n**立即执行：重写服务脚本（使用 FAISS）。**\n\n"},{"type":"toolCall","id":"call_e2052eed767f4e02a9c5bf33","name":"write","arguments":{"path":"/home/zigaa/.openclaw/workspace/workspace-develop/rag_service_faiss.py","content":"\"\"\"\nRAG 系统服务 - FAISS 版（仅 vLLM + 简化嵌入）\n\n环境：Python 3.12 + uv venv\n技术栈：LlamaIndex + FAISS（本地）+ vLLM（简化嵌入）\n\"\"\"\n\nimport os\nfrom pathlib import Path\nfrom llama_index.core import VectorStoreIndex, StorageContext\nfrom llama_index.core import ServiceContext, Document\nfrom llama_index.llms.vllm import Vllm\nfrom llama_index.vector_stores.faiss import FaissVectorStore\nfrom fastapi import FastAPI\nimport uvicorn\nimport faiss\n\n# 配置参数\nVLLM_API_KEY = \"sk-123456789abcdef\"\nVLLM_API_URL = \"http://localhost:11435/v1\"\nVLLM_MODEL_NAME = \"qwen3.5-9b\"\nPERSIST_DIR = \"/home/zigaa/.openclaw/workspace/workspace-develop/data/index\"\n\n# 简化嵌入模型（使用硬编码向量或简单逻辑）\ndef get_embedding(text):\n    \"\"\"简化嵌入：使用固定向量（实际应用中应使用真实嵌入模型）\"\"\"\n    import hashlib\n    hash_val = hashlib.md5(text.encode()).hexdigest()\n    vector = [int(c, 16) / 15.0 for c in hash_val]  # 归一化到 [-1, 1]\n    return vector\n\n# 配置 LLM 模型\nprint(\"=\" * 50)\nprint(\"RAG 系统服务启动（vLLM + FAISS + 简化嵌入）\")\nprint(\"=\" * 50)\n\nprint(\"\\n配置 LLM 模型...\")\nllm = Vllm(\n    model=VLLM_MODEL_NAME,\n    api_url=VLLM_API_URL,\n    vllm_kwargs={\n        \"model\": VLLM_MODEL_NAME,\n        \"api_key\": VLLM_API_KEY\n    }\n)\nprint(f\"  LLM 模型：{llm}\")\n\n# 配置简化嵌入模型\nprint(\"\\n配置简化嵌入模型...\")\nprint(\"  使用简化嵌入逻辑（硬编码向量）\")\n\n# 配置向量数据库（本地 FAISS）\nprint(\"\\n配置向量数据库...\")\nfaiss_index = faiss.IndexFlatL2(768)  # 默认 768 维\nfaiss_dir = os.path.join(PERSIST_DIR, \"faiss_index\")\nfaiss_vector_store = FaissVectorStore(faiss_index=faiss_index, persist_dir=faiss_dir)\nprint(f\"  向量数据库：{faiss_vector_store}\")\n\n# 加载文档\nprint(\"\\n加载文档...\")\nstorage_context = StorageContext.from_defaults(vector_store=faiss_vector_store)\ndocuments = [\n    Document(text=\"RAG 是一种检索增强生成技术，它结合了检索和生成两种能力。\"),\n    Document(text=\"这是一个简单的 RAG 系统示例，使用 LlamaIndex 框架。\"),\n    Document(text=\"LlamaIndex 是一个用于构建 RAG 应用的框架。\")\n]\n\n# 创建服务上下文（使用简化嵌入）\nprint(\"\\n创建服务上下文...\")\nservice_context = ServiceContext.from_defaults(\n    llm=llm,\n    embed_model=lambda x: get_embedding(x)\n)\n\n# 构建索引\nprint(\"\\n构建 RAG 索引...\")\nindex = VectorStoreIndex.from_documents(\n    documents=documents,\n    service_context=service_context,\n    storage_context=storage_context\n)\nprint(\"  索引构建成功！\")\n\n# 测试查询\nprint(\"\\n测试查询...\")\nquery_engine = index.as_query_engine()\nresponse = query_engine.query(\"什么是 RAG?\")\nprint(f\"  回答：{response}\")\n\nprint(\"\\n\" + \"=\" * 50)\nprint(\"RAG 系统服务启动成功！\")\nprint(\"=\" * 50)\n\n# 启动 FastAPI 服务\napp = FastAPI(title=\"RAG API\")\n\n@app.get(\"/query\")\nasync def query(query_text: str):\n    response = index.as_query_engine().query(query_text)\n    return {\"answer\": str(response)}\n\n@app.get(\"/health\")\nasync def health():\n    return {\"status\": \"ok\", \"service\": \"RAG API\"}\n\nprint(\"\\n启动 FastAPI 服务...\")\nprint(\"  访问地址：http://localhost:8000\")\nprint(\"  健康检查：http://localhost:8000/health\")\nprint(\"  查询接口：http://localhost:8000/query?query_text=你的问题\")\n\nuvicorn.run(app, host=\"0.0.0.0\", port=8000, log_level=\"warning\")"}}],"api":"openai-completions","provider":"vllm","model":"qwen3.5-9b","usage":{"input":64166,"output":1132,"cacheRead":0,"cacheWrite":0,"totalTokens":65298,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776325492642,"responseId":"chatcmpl-b2564a0f626bf488"}}
