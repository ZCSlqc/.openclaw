{"type":"message","id":"b1ebc7da","parentId":"233774e1","timestamp":"2026-04-16T06:56:22.360Z","message":{"role":"assistant","content":[{"type":"text","text":"好的，大哥。我需要提供 `content` 参数。\n\n**立即执行：编写数据清洗脚本。**\n\n"},{"type":"toolCall","id":"call_8d86abc0d3764248aa359689","name":"write","arguments":{"path":"/home/zigaa/.openclaw/workspace/workspace-develop/data_cleaner.py","content":"\"\"\"\n数据清洗脚本：将文档分割为 chunk，准备用于 RAG 索引构建。\n\n环境：Python 3.12 + uv venv\n技术栈：LlamaIndex\n\"\"\"\n\nimport os\nimport re\nfrom pathlib import Path\nfrom typing import List, Tuple\n\n# 配置参数\nCHUNK_SIZE = 500  # 每个 chunk 的字符数\nCHUNK_OVERLAP = 50  # chunk 之间的重叠字符数（用于保持上下文连贯性）\n\n\ndef clean_text(text: str) -> str:\n    \"\"\"\n    清理文本，去除多余空白、换行符、特殊字符等。\n    \"\"\"\n    # 去除多余空白和换行符\n    text = re.sub(r'\\s+', ' ', text)\n    # 去除特殊字符（保留字母、数字、中文、空格）\n    text = re.sub(r'[^\\w\\s\\u4e00-\\u9fff]', '', text)\n    # 去除首尾空白\n    text = text.strip()\n    return text\n\n\ndef split_into_chunks(text: str, chunk_size: int, overlap: int) -> List[Tuple[str, str]]:\n    \"\"\"\n    将文本分割为多个 chunk，保持重叠部分以维持上下文连贯性。\n    \n    返回：[(chunk_text, overlap_text), ...]\n    \"\"\"\n    chunks = []\n    current_text = text\n    current_chunk = \"\"\n    \n    # 逐字符分割，保留重叠部分\n    while current_text:\n        # 计算当前 chunk 的结束位置\n        end_pos = min(len(current_chunk) + chunk_size, len(current_text))\n        chunk_text = current_text[:end_pos]\n        \n        # 提取重叠部分\n        overlap_text = current_text[max(0, end_pos - overlap):end_pos]\n        \n        chunks.append((chunk_text, overlap_text))\n        \n        # 更新 current_text，跳过已处理部分（重叠部分不重复处理）\n        current_text = current_text[end_pos:]\n        current_chunk = \"\"\n    \n    return chunks\n\n\ndef process_documents(input_dir: str, output_dir: str):\n    \"\"\"\n    处理输入目录下的所有文档，分割为 chunk 并保存。\n    \"\"\"\n    input_path = Path(input_dir)\n    output_path = Path(output_dir)\n    output_path.mkdir(parents=True, exist_ok=True)\n    \n    print(f\"开始处理目录：{input_dir}\")\n    print(f\"输出目录：{output_dir}\")\n    print(f\"Chunk 配置：size={CHUNK_SIZE}, overlap={CHUNK_OVERLAP}\")\n    print(\"-\" * 50)\n    \n    # 遍历所有文件\n    for file_path in input_path.iterdir():\n        if file_path.is_file() and file_path.suffix in ['.txt', '.md', '.pdf']:\n            print(f\"\\n处理文件：{file_path.name}\")\n            \n            # 读取文件内容\n            try:\n                if file_path.suffix == '.pdf':\n                    # PDF 文件需要额外处理（这里简化为示例）\n                    content = \"PDF 文件处理待完善...\"\n                else:\n                    content = file_path.read_text(encoding='utf-8')\n            except Exception as e:\n                print(f\"  读取失败：{e}\")\n                continue\n            \n            # 清理文本\n            cleaned_text = clean_text(content)\n            print(f\"  原始字符数：{len(content)}\")\n            print(f\"  清理后字符数：{len(cleaned_text)}\")\n            \n            # 分割为 chunk\n            chunks = split_into_chunks(cleaned_text, CHUNK_SIZE, CHUNK_OVERLAP)\n            print(f\"  分割为 {len(chunks)} 个 chunk\")\n            \n            # 保存 chunk\n            chunk_file = output_path / f\"{file_path.stem}_chunks.txt\"\n            with open(chunk_file, 'w', encoding='utf-8') as f:\n                for i, (chunk_text, overlap_text) in enumerate(chunks):\n                    f.write(f\"=== Chunk {i+1} ===\\n\")\n                    f.write(f\"Content: {chunk_text}\\n\")\n                    f.write(f\"Overlap: {overlap_text}\\n\\n\")\n            \n            print(f\"  已保存到：{chunk_file}\")\n    \n    print(\"\\n\" + \"=\" * 50)\n    print(\"数据清洗完成！\")\n    print(f\"输出目录：{output_path}\")\n    print(\"下一步：使用 LlamaIndex 构建索引\")\n\n\nif __name__ == \"__main__\":\n    # 配置输入输出目录\n    INPUT_DIR = \"/home/zigaa/.openclaw/workspace/workspace-develop/data/input\"\n    OUTPUT_DIR = \"/home/zigaa/.openclaw/workspace/workspace-develop/data/chunks\"\n    \n    # 检查输入目录\n    if not os.path.exists(INPUT_DIR):\n        print(f\"输入目录不存在：{INPUT_DIR}\")\n        print(\"请创建输入目录并添加文档文件（.txt, .md, .pdf）\")\n    else:\n        # 执行数据清洗\n        process_documents(INPUT_DIR, OUTPUT_DIR)"}}],"api":"openai-completions","provider":"vllm","model":"qwen3.5-9b","usage":{"input":59710,"output":1196,"cacheRead":0,"cacheWrite":0,"totalTokens":60906,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776322567696,"responseId":"chatcmpl-8ec912c0be2f8701"}}
