{"type":"message","id":"fe835d47","parentId":"136e709f","timestamp":"2026-04-16T07:18:04.208Z","message":{"role":"assistant","content":[{"type":"text","text":"好的，大哥。向量数据库配置已完成。\n\n**下一步：创建完整的 RAG 服务脚本，整合所有配置。**\n\n**立即执行：创建 RAG 服务脚本。**\n\n"},{"type":"toolCall","id":"call_f48202d02fb24f7ea0fd674d","name":"write","arguments":{"path":"/home/zigaa/.openclaw/workspace/workspace-develop/rag_service.py","content":"\"\"\"\nRAG 系统服务 - 完整实现\n\n环境：Python 3.12 + uv venv\n技术栈：LlamaIndex + Chroma + vLLM/DeepSeek\n\"\"\"\n\nimport os\nimport yaml\nfrom pathlib import Path\nfrom llama_index.core import VectorStoreIndex, StorageContext\nfrom llama_index.core import ServiceContext, Document\nfrom llama_index.embeddings.huggingface import HuggingFaceEmbedding\nfrom llama_index.llms.huggingface import HuggingFacePipeline\nfrom llama_index.vector_stores.chroma import ChromaVectorStore\nfrom llama_index.core import Settings\n\n# 加载配置\ndef load_config():\n    \"\"\"加载配置参数\"\"\"\n    config = {\n        \"embedding\": load_yaml(\"/home/zigaa/.openclaw/workspace/workspace-develop/config_embedding.yaml\"),\n        \"llm\": load_yaml(\"/home/zigaa/.openclaw/workspace/workspace-develop/config_llm.yaml\"),\n        \"vectorstore\": load_yaml(\"/home/zigaa/.openclaw/workspace/workspace-develop/config_vectorstore.yaml\")\n    }\n    return config\n\ndef load_yaml(path):\n    \"\"\"加载 YAML 配置\"\"\"\n    try:\n        with open(path, 'r', encoding='utf-8') as f:\n            return yaml.safe_load(f)\n    except Exception as e:\n        print(f\"配置加载失败：{e}\")\n        return {}\n\n# 配置嵌入模型\ndef setup_embedding_model(config):\n    \"\"\"配置嵌入模型\"\"\"\n    emb_config = config.get(\"embedding\", {})\n    emb_type = emb_config.get(\"embedding_model_type\", \"huggingface\")\n    \n    if emb_type == \"vllm\":\n        from llama_index.embeddings.vllm import VllmEmbedding\n        model = VllmEmbedding(\n            model=emb_config.get(\"embedding_model_name\", \"qwen3.5-9b\"),\n            api_key=emb_config.get(\"vllm_api_key\"),\n            base_url=emb_config.get(\"vllm_base_url\")\n        )\n    elif emb_type == \"deepseek\":\n        # DeepSeek 嵌入模型（需自定义实现）\n        from llama_index.embeddings.base import BaseEmbedding\n        class DeepSeekEmbedding(BaseEmbedding):\n            def __init__(self, model_name, api_key, base_url):\n                self.model_name = model_name\n                self.api_key = api_key\n                self.base_url = base_url\n            \n            def _get_query_embedding(self, query):\n                # 这里需要实现 DeepSeek 嵌入模型调用\n                # 示例：使用 HuggingFace 作为 fallback\n                return HuggingFaceEmbedding(model_name=\"sentence-transformers/all-MiniLM-L6-v2\").get_query_embedding(query)\n            \n            def _get_text_embedding(self, text):\n                return self._get_query_embedding(text)\n        \n        model = DeepSeekEmbedding(\n            model_name=emb_config.get(\"embedding_model_name\", \"deepseek-chat\"),\n            api_key=emb_config.get(\"deepseek_api_key\"),\n            base_url=emb_config.get(\"deepseek_base_url\")\n        )\n    else:\n        # 默认：HuggingFace\n        model = HuggingFaceEmbedding(\n            model_name=emb_config.get(\"embedding_model_name\", \"sentence-transformers/all-MiniLM-L6-v2\")\n        )\n    \n    return model\n\n# 配置 LLM 模型\ndef setup_llm(config):\n    \"\"\"配置 LLM 模型\"\"\"\n    llm_config = config.get(\"llm\", {})\n    llm_type = llm_config.get(\"llm_type\", \"huggingface\")\n    \n    if llm_type == \"vllm\":\n        from llama_index.llms.vllm import Vllm\n        llm = Vllm(\n            model=llm_config.get(\"llm_model_name\", \"qwen3.5-9b\"),\n            api_key=llm_config.get(\"vllm_api_key\"),\n            base_url=llm_config.get(\"vllm_base_url\")\n        )\n    elif llm_type == \"deepseek\":\n        from llama_index.llms.openai import OpenAI\n        llm = OpenAI(\n            model=llm_config.get(\"llm_model_name\", \"deepseek-chat\"),\n            api_key=llm_config.get(\"deepseek_api_key\"),\n            base_url=llm_config.get(\"deepseek_base_url\")\n        )\n    else:\n        # 默认：HuggingFace\n        from llama_index.llms.huggingface import HuggingFacePipeline\n        llm = HuggingFacePipeline(\n            model=llm_config.get(\"default_llm_model\", \"gpt-4o-mini\")\n        )\n    \n    return llm\n\n# 配置向量数据库\ndef setup_vectorstore(config):\n    \"\"\"配置向量数据库\"\"\"\n    vs_config = config.get(\"vectorstore\", {})\n    vs_type = vs_config.get(\"vectorstore_type\", \"chroma\")\n    persist_dir = vs_config.get(\"vectorstore_persist_dir\", \"/home/zigaa/.openclaw/workspace/workspace-develop/data/index\")\n    \n    if vs_type == \"chroma\":\n        from llama_index.vector_stores.chroma import ChromaVectorStore\n        vectorstore = ChromaVectorStore(\n            persist_dir=persist_dir,\n            collection_name=\"rag_index\"\n        )\n    elif vs_type == \"faiss\":\n        from llama_index.vector_stores.faiss import FaissVectorStore\n        import faiss\n        dim = 768  # 根据嵌入模型调整\n        index = faiss.IndexFlatL2(dim)\n        vectorstore = FaissVectorStore(faiss_index=index)\n    else:\n        # 默认：Chroma\n        from llama_index.vector_stores.chroma import ChromaVectorStore\n        vectorstore = ChromaVectorStore(\n            persist_dir=persist_dir,\n            collection_name=\"rag_index\"\n        )\n    \n    return vectorstore\n\n# 创建 RAG 索引\ndef create_rag_index(storage_context, documents):\n    \"\"\"创建 RAG 索引\"\"\"\n    index = VectorStoreIndex.from_documents(\n        documents=documents,\n        storage_context=storage_context\n    )\n    return index\n\n# 主服务\ndef main():\n    \"\"\"主服务入口\"\"\"\n    print(\"=\" * 50)\n    print(\"RAG 系统服务启动\")\n    print(\"=\" * 50)\n    \n    # 加载配置\n    config = load_config()\n    \n    # 配置嵌入模型\n    print(\"\\n配置嵌入模型...\")\n    embedding_model = setup_embedding_model(config)\n    print(f\"  嵌入模型：{embedding_model}\")\n    \n    # 配置 LLM 模型\n    print(\"\\n配置 LLM 模型...\")\n    llm = setup_llm(config)\n    print(f\"  LLM 模型：{llm}\")\n    \n    # 配置向量数据库\n    print(\"\\n配置向量数据库...\")\n    vectorstore = setup_vectorstore(config)\n    print(f\"  向量数据库：{vectorstore}\")\n    \n    # 加载文档\n    print(\"\\n加载文档...\")\n    storage_context = StorageContext.from_defaults(vector_store=vectorstore)\n    documents = [\n        Document(text=\"RAG 是一种检索增强生成技术，它结合了检索和生成两种能力。\"),\n        Document(text=\"这是一个简单的 RAG 系统示例，使用 LlamaIndex 框架。\"),\n        Document(text=\"LlamaIndex 是一个用于构建 RAG 应用的框架。\")\n    ]\n    \n    # 创建索引\n    print(\"\\n创建 RAG 索引...\")\n    index = create_rag_index(storage_context, documents)\n    print(\"  索引创建成功！\")\n    \n    # 测试查询\n    print(\"\\n测试查询...\")\n    query_engine = index.as_query_engine()\n    response = query_engine.query(\"什么是 RAG?\")\n    print(f\"  回答：{response}\")\n    \n    print(\"\\n\" + \"=\" * 50)\n    print(\"RAG 系统服务启动成功！\")\n    print(\"=\" * 50)\n    \n    # 启动 FastAPI 服务\n    from fastapi import FastAPI\n    from fastapi.responses import StreamingResponse\n    import uvicorn\n    \n    app = FastAPI(title=\"RAG API\")\n    \n    @app.get(\"/query\")\n    async def query(query_text: str):\n        response = index.as_query_engine().query(query_text)\n        return {\"answer\": str(response)}\n    \n    print(\"\\n启动 FastAPI 服务...\")\n    uvicorn.run(app, host=\"0.0.0.0\", port=8000)\n\nif __name__ == \"__main__\":\n    main()"}}],"api":"openai-completions","provider":"vllm","model":"qwen3.5-9b","usage":{"input":72789,"output":2002,"cacheRead":0,"cacheWrite":0,"totalTokens":74791,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776323859329,"responseId":"chatcmpl-b413cc67aadba3cd"}}
